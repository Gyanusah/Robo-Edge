{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/api/auth.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/notices.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/gallery.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/testimonials.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/contact.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/backend/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]

}
