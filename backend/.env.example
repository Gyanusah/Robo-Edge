# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/your-database-name?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Environment
NODE_ENV=production

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Default Admin (for initial setup)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=admin123456

# Admin Creation Settings
ALLOW_ADMIN_CREATION=true
ADMIN_CREATION_TOKEN=secure_admin_creation_token
